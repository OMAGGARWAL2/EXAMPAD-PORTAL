
$('.notification-icon').qtip({ // Grab some elements to apply the tooltip to
		    content: {
		        text: 'Notifications'
		    },
		    position: {
		        my: 'top center',  // Position my top left...
		        at: 'bottom center', // at the bottom right of...
		        adjust: {
		            x: 0,
		            y: 14
		        }
		        
		    },
		    style: {
		        classes: 'qtip-tipsy qtip-shadow'
		    },
		    hide: { 
		    	event: 'click mouseleave'
		    	
		    },
			api: {
				onRender: function() {
					// Hide the tooltip when it is clicked
					this.elements.tooltip.click(this.hide)
				},
				onHide: function() {
					// Set a state cookie
					$.cookie('qtip_hidden', true, { path: '/', expires: 10 });
 
					// Destroy me since I have no futher use!
					this.destroy();
				}
			}
});
