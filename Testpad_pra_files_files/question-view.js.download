const nextContentLinkUrl = `/api/attempt/nextcontentlink/${container._id}/${question._id}`;
const defaultCode = {};
const codeComponentObj = {};
const cachedResult = {};

let editor;
let editorHead;
let editorTail;
let webEditorContent = {};
let defaultWebEditorContent = {};
let snapshots = [];
let snapshotIntervalId = null;
let executionType;
let mcqExplanation;
let lastSelectedLanguage;
const errorInLoadScript = 0;
let webTestsWarningTimeout = null;
let webTestsFailTimeout = null;
let currentTab = 'html';
let sampleTestCaseCount = 0;
const rowSeprator = '\n';
const colSeprator = ',';
let traceTableTestcaseMap = new Map();
let traceTableTestCaseIndex = (question.questionTypeCoding && question.questionTypeCoding.tableTestCaseIndex) || 0;

if(question && question.type == 4 && question.questionTypeCoding && question.questionTypeCoding.testCase){
  question.questionTypeCoding.testCase.forEach((val)=>{
    if(val.sampleTest){
      sampleTestCaseCount++;
    }
  })
}

function getNextContentLink() {
  $.ajax({
    type: 'GET',
    url: nextContentLinkUrl,
    dataType: 'json',
    success(data = {}) {
      if (data.nextLink) {
        $('.next-question').attr('href', data.nextLink);
        $('.next-question').css('display', 'block');
      }

      if (data.share) {
        $('#progress-container').empty();
        $('#progress-container').append(`
            <div class="left-bar-share-segment-container">
              <div class="share-bar-text-container">
                <p class="hurr-text-left-bar">HURRAY!</p>
                <p class="complete-segment-text-left-bar">THIS SECTION IS COMPLETE!</p>
                <p class="share-this-left-bar">SHARE THIS WITH YOUR FRIENDS?</p>
                <p class="share-percentage-covered">100% covered</p>
                <div>
                  <div class="progess-bar-share-left-side-bar"></div>
                </div>
              </div>
            </div>
          `);
        $('#progress-container').addClass('share-container-left-bar');
        $('.left-side-bar-main-content').css('height', 'calc(100vh - 190px)');

        sharingPercentageDisable = true;

        if (data.segmentData
          && data.segmentData.segmentObj
          && data.segmentData.segmentObj.shareMsg
        ) {
          toggleShareModal(data.segmentData.segmentObj.shareMsg);
        } else {
          toggleShareModal();
        }
      }
    },
    error(jqXHR, textStatus, err) {
      console.error('error get next content link ---> ', err);
      // notie.alert(3, "Error in updating order" + err, 4);
    },
  });
}

function onProgrammingLanguageChange() {
  let valueProgLang = $('#progLang').val();

  // show bash terminal button
  if(question.type === '4' && valueProgLang == '11'){
     $("#openBashTerminal").css('display','');
  }else if(question.type === '4'){
    $("#openBashTerminal").css('display','none');
  }

  if (!valueProgLang) {
    valueProgLang = $('#progLang').val($('#progLang option:first').val()).val();
  }

  if (lastSelectedLanguage && valueProgLang != lastSelectedLanguage) {
    codeComponentObj[lastSelectedLanguage].body = editor.getValue();
  }

  editor.setOption('mode', getModeFromLangCode(valueProgLang));
  editor.getDoc().setValue(codeComponentObj[valueProgLang].body || '');

  editor.clearHistory();

  if (question.showHead || session.role != 1) {
    editorHead.setOption('mode', getModeFromLangCode(valueProgLang));
    codeComponentObj[valueProgLang].head ? codeComponentObj[valueProgLang].head : codeComponentObj[valueProgLang].head = ' ';
    editorHead.getDoc().setValue(codeComponentObj[valueProgLang].head);
  }

  if (question.showTail || session.role != 1) {
    editorTail.setOption('mode', getModeFromLangCode(valueProgLang));
    codeComponentObj[valueProgLang].tail ? codeComponentObj[valueProgLang].tail : codeComponentObj[valueProgLang].tail = ' ';
    editorTail.getDoc().setValue(codeComponentObj[valueProgLang].tail);
  }

  lastSelectedLanguage = valueProgLang;
}

function saveSnapshot() {
  if ($('#executeProgram').prop('disabled')) {
    return;
  }

  if (question.type === '3' || question.type === '4') {
    snapshots.push({
      code: editor.getValue(),
      timeOfCreation: Date.now(),
    });
  }
}

async function getQuestionAttemptsData() {
  let url;
  if (userIdStudent) {
    url = `/api/useranswer/attemptedQuestion/${userIdStudent}/${emailHash}/${courseId}/${question._id}/all`;
  } else {
    url = `/api/attempts/attemptedQuestion/${emailHash}/${courseId}/${question._id}/all`;
  }

  //toggleLoader(true);
  $('#nav-attempts').html(`<div class='attempts-loader'> 
    <div class='loading-spinner-container'>
      <div class="loading-spinner">
        <div></div>
        <div></div>
        <div></div>
        <div></div>
      </div>
    </div>
  </div>
  <div style="text-align: center;">
    <label class="container-radio">
      ALL (<span class="allCount">0</span>)
      <input type="radio" value="all" name="attemptsFilter" class="all-select all-select-selected" checked="checked" />
      <span class="checkmark"></span>
    </label>
    
    <label class="container-radio">
      Failed (<span class="failedCount">0</span>)
      <input type="radio" value="failed" name="attemptsFilter" class="all-select" />
      <span class="checkmark"></span>
    </label>

    <label class="container-radio">
      Successful (<span class="successCount">0</span>)
      <input type="radio" value="success" name="attemptsFilter" class="all-select" />
      <span class="checkmark"></span>
    </label>

    ${(() => {
      if (question.type == '4') {
        return `
          <label class="container-radio">
            Compile error (<span class="errorCount">0</span>)
            <input
                type="radio"
                value="error"
                name="attemptsFilter"
                class="all-select"    
            />
            <span class="checkmark"></span>
          </label>
        `;
      }
      return '';
    })()}
  </div>
  <div class="attempts-head">
        <p>Attempts</p>
        <p>Test cases</p>
        <p>Status</p>
    </div>
    <div class="attempts-body">
    
    </div>
  `);

  let data;
  try {
    const response = await fetch(url);
// need to change
  if(response.redirected) {
    console.log('Before Get response redirect', response);
    if(response.url && response.url.indexOf('login') > -1) location.reload();
    else window.location = `${response.url}`;
  } 
// need to change

    data = await response.json();

    if (data.error) {
      throw new Error(data.error);
    }

    $('#nav-attempts').html(`
    ${(() => {
      if (question.type != '10' && question.type != '2') {
        return `
          <div style="text-align: center;">
            <label class="container-radio">
              ALL (<span class="allCount">0</span>)
              <input type="radio" value="all" name="attemptsFilter" class="all-select all-select-selected" checked="checked" />
              <span class="checkmark"></span>
            </label>
            
            <label class="container-radio">
              Failed (<span class="failedCount">0</span>)
              <input type="radio" value="failed" name="attemptsFilter" class="all-select" />
              <span class="checkmark"></span>
            </label>
        
            <label class="container-radio">
              Successful (<span class="successCount">0</span>)
              <input type="radio" value="success" name="attemptsFilter" class="all-select" />
              <span class="checkmark"></span>
            </label>
        
            ${(() => {
              if (question.type == '4') {
                return `
                  <label class="container-radio">
                    Compile error (<span class="errorCount">0</span>)
                    <input
                        type="radio"
                        value="error"
                        name="attemptsFilter"
                        class="all-select"    
                    />
                    <span class="checkmark"></span>
                  </label>
                `;
              }
              return '';
            })()}
          </div>
        `;
      }
      return '';
    })()}
    
    <div class="attempts-head">
        <p>Attempts</p>
        <p>Test cases</p>
        <p>Status</p>
    </div>
    <div class="attempts-body">
    
    </div>
  `);
    const attemptData = data.userAttempts;
    const columns = data.columns;

    if (attemptData.attemptData) {
      attemptData.attemptData.forEach((attemptObj) => {
        const createdAt = new Date(attemptObj.created_at);
        const createdDate = createdAt.toLocaleDateString();
        const createdTime = createdAt.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        let testCase = 'N/A';
        let result;
        if (attemptData.type == '1') {
          result = attemptObj.isMCQCorrect ? 'correct' : 'incorrect';
        } else if (attemptData.type == '3' || attemptData.type == '4' || attemptData.type == '5' || attemptData.type == '9' || attemptData.type == '10') {
          if (attemptObj[columns.userCompilationError]) {
            result = 'error';
            if (attemptObj[columns.totalTestCases]) {
              testCase = `0 / ${attemptObj[columns.totalTestCases]}`;
            }
          } else if (typeof question.funcType !== 'undefined' && question.funcType != 0) {
            testCase = 'N/A';
            const tcPassed = attemptObj[columns.testCasePassed] ? attemptObj[columns.testCasePassed] : 0;
            const tcTotal = attemptObj[columns.totalTestCases] ? attemptObj[columns.totalTestCases] : 0;
            result = (tcPassed != 0 && tcPassed == tcTotal) ? 'success' : 'failed';
          } else {
            result = attemptObj[columns.totalTestCases] == attemptObj[columns.testCasePassed] ? 'success' : 'failed';
            if (attemptObj[columns.totalTestCases]) {
              testCase = `${attemptObj[columns.testCasePassed] || 0} / ${attemptObj[columns.totalTestCases]}`;
            }
          }
        }

        let classType;
        if (result == 'error') {
          classType = 'error';
        } else if (result == 'correct' || result == 'success') {
          classType = 'success';
        } else {
          classType = 'failed';
        }

        if (attemptData.type == '2' || attemptData.type == '10') {
          classType = '';
          result = 'attempted';
        }

        if (question
          && question.questionTypeCoding
          && question.questionTypeCoding.executionType
          && question.questionTypeCoding.executionType == 1
        ) {
          testCase = 'N/A';
        }

        $('.attempts-body').append(`
          <div class=${classType}>
            <p>${createdDate} | ${createdTime}</p>
                ${(() => {
    if (attemptData.type == '4' || attemptData.type == '9') {
      if(result == 'error'){
        testCase = 'N/A'
      }
      return `
                <p style="color:#de6d55;" title="Preview in CodeStub"><a style="cursor:pointer;width:unset;" onclick="populateAttempt('/api/quest/userattempt/${attemptObj._id}')">${testCase}</a>
                </p>`;
    }
    return `<p>${testCase}  &nbsp; </p>`;
  })()}
               ${attemptData.type == '10' ? `<p style="cursor:pointer;" onclick="document.getElementById('project-link').value = '${attemptObj.user_program || ''}'"> <a class="res">${result}</a> </p>` :
    `<p> <a target="_blank" href="/quest/preview/userattempt/${attemptObj._id}" class="res">${result}&nbsp;&nbsp;</a> </p>`}
          </div>
      `);
      });
      //attempts-body attemps status count
      $(document).ready(function () {
        $(".allCount").html($(".attempts-body").children().length);
        $(".failedCount").html($(".attempts-body").find(".failed").length);
        $(".successCount").html($(".attempts-body").find(".success").length);
        $(".errorCount").html($(".attempts-body").find(".error").length);
      })
    } else {
      $('.attempts-body').append(`
        <div>
          <p style="color: #DE6834">No Records Found!</p>
        </div>
    `);
    }

    // eslint-disable-next-line func-names
    $('input[name="attemptsFilter"]').on('click', function () {
      const resultType = $(this).val() ? $(this).val() : 'all';

      if (resultType == 'error') {
        $('.attempts-body').find('.failed').hide();
        $('.attempts-body').find('.success').hide();
        $('.attempts-body').find('.error').show();
      } else if (resultType == 'failed') {
        $('.attempts-body').find('.error').hide();
        $('.attempts-body').find('.success').hide();
        $('.attempts-body').find('.failed').show();
      } else if (resultType == 'success') {
        $('.attempts-body').find('.error').hide();
        $('.attempts-body').find('.failed').hide();
        $('.attempts-body').find('.success').show();
      } else {
        $('.attempts-body').find('.error').show();
        $('.attempts-body').find('.failed').show();
        $('.attempts-body').find('.success').show();
      }
    });

    toggleLoader(false);
  } catch (error) {
    toggleLoader(false);
    console.log(error);
    // alert(error.message);
  }
}

async function populateAttempt(url) {
  try {
    const response = await fetch(url);
    if(response.redirected) {
      console.log('Before Get response redirect', response);
      if(response.url && response.url.indexOf('login') > -1) location.reload();
      else window.location = `${response.url}`;
    } 
    const attemptsData = await response.json();

    if (attemptsData.error) {
      throw new Error(attemptsData.error);
    }

    if (attemptsData.ques.type === '9') {
      webEditorContent.html = attemptsData.userAttempt.html;
      webEditorContent.css = attemptsData.userAttempt.css;
      webEditorContent.js = attemptsData.userAttempt.js;

      editor.setValue(webEditorContent[currentTab]);
      $('#preview').click();
    } else {
      const stringifyQues = JSON.parse(attemptsData.stringifyQues)[0];
      
      if(attemptsData && attemptsData.userAttempt && attemptsData.userAttempt.user_language && !codeComponentObj[attemptsData.userAttempt.user_language]) {
        console.log(attemptsData)
        toggleAlertMsgModal("Language removed from this question.", 2);
        return;
      }
      
      codeComponentObj[stringifyQues.language].head = stringifyQues.codeComponents.head;
      codeComponentObj[stringifyQues.language].body = stringifyQues.codeComponents.body;
      codeComponentObj[stringifyQues.language].tail = stringifyQues.codeComponents.tail;

      $('#progLang').val(stringifyQues.language);
      $('#progLang').change();
    }
  } catch (error) {
    alert(error.message);
  }
}

function openInPlayground() {
  const data = {
    editorValue: `${typeof editorHead === 'object' ? `${editorHead.getValue()}\n` : ''}${editor.getValue()}${typeof editorTail === 'object' ? `\n${editorTail.getValue()}` : ''}`,
    language: lastSelectedLanguage,
    customInput: $('#stdin').val().trim(),
  };

  localStorage.setItem('attemptInIDE', JSON.stringify(data));

  window.open('/playground?fromAttempt=1', '_blank');
}

function handleCompletionStatusUpdate(data) {
  if (data.isCompleted) {
    isCompleted = true;
    getNextContentLink();
    getContentOfCurrentSegment(mainSegment, container._id);
  }
}

function handleMCQResult(data) {
  console.log('mcq result data -----> ', data);

  $(".dmr").css('display','none');
  $('.imgMCQ').remove();
  $('.mcq-result-text').remove();
  
  const valueMCQ = $("input[name='chk']:checked", '#question').val().replace('chkOpt', '');
  const index = parseInt(valueMCQ, 10) - 1;
  if (data.result.indexOf(index) !== -1) {
    $("#divMCQResult"+index).html('<img id="imgMCQ" src="/icons/check1.svg" style="margin-left: 10px;" class="correct_result"/><span class="mcq-result-text"><span class="text-success">correct answer</span></span>')
    $("#divMCQResult"+index).css("display", "block");
  } else {
    $("#divMCQResult"+index).html('<img id="imgMCQ" src="/icons/interface.svg" style="margin-left: 10px;" class="correct_result"/><span class="mcq-result-text"><span class="text-danger">your answer</span></span>')
    $("#divMCQResult"+index).css("display", "block");

  }

  data.result.forEach((val)=>{
    let correctIndex = val;
    $("#divMCQResult"+correctIndex).html('<img id="imgMCQ" src="/icons/check1.svg" style="margin-left: 10px;" class="correct_result"/><span class="mcq-result-text"><span class="text-success">correct answer</span></span>')
    $("#divMCQResult"+correctIndex).css("display", "block");
})

  $('#divMCQResult').css('display', 'block');
  $('.see-explain').css('display', 'block');

  if (mcqExplanation === '<p><br></p>') {
    $('#explanation').css('display', 'none');
  }

  $('#executeMCQ').prop('disabled', false);
  $('#executeMCQ').prop('value', 'Submit');
}

function onSubmitMCQClick(event) {
  event.preventDefault();

  const chosenOption = $("input[name='chk']:checked", '#question').val();
  if (!chosenOption) {
    toggleAlertMsgModal('Please select at least one option.',2);
    return;
  }

  if(!session.userId){
    let url = window.location.href.replace(/\+/g,'%2B');
    let isCourseId = new URL(window.location.href).searchParams.get('courseId');
    if(isCourseId){
        toggleLoginForm('/',`/attempt/attemptquestion/${isCourseId}/${question._id}`);
    }else{
        toggleLoginForm('/',`${url}`)
    }
    return;
  }


  $(this).prop('disabled', true);
  $(this).prop('value', 'Submitting...');


  const payloadMCQ = {
    questionId: question._id,
    containerId: container._id,
    inputMCQ: chosenOption,
    isCompleted,
    sid: sessionStorage.getItem('sid'),
    parentId: session.parentId,
    courseId,
  };

  if (socket.connected) {
    socket.emit('getmcqresult', payloadMCQ);
  } else {
    toggleAlertMsgModal('Session expired, Please login',2);
  }
}

function showExplanation(el) {
  $(el).parent().next().next()
    .slideToggle();
  $(el).find('i').toggleClass('fa-caret-up');
  $(el).find('i').toggleClass('fa-caret-down');
}

async function reviewCodeLink() {
  const langId = $('#progLang').val();
  let data = {
    quesId: question._id,
  };

  if (question.type == 4) {
    const code = editor.getValue().trim();
    data = {
      ...data,
      langId,
      code,
    };

    if($('#customInput').is(':checked')){
      let customInputVal = $('#stdin').val();
      data.customInputVal = customInputVal;
    }

  } else if (question.type == 9) {
    webEditorContent[currentTab] = editor.getValue().trim();
    data = {
      ...data,
      langId: '22',
      html: webEditorContent.html,
      css: webEditorContent.css,
      js: webEditorContent.js,
    };
  }

  const response = await fetch('/api/quest/codeSnippet', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(data),
  });
  if(response.redirected) {
    console.log('Before Get response redirect', response);
    if(response.url && response.url.indexOf('login') > -1) location.reload();
    else window.location = `${response.url}`;
  } 
  const link = await response.json();

  $('.share-code-popup-container').removeClass('d-none');
  $('#shareLink').text(link.url);
  $('#shareLink').attr('title', link.url);
}

function closeShareModal() {
  $('.share-code-popup-container').addClass('d-none');
}

async function copyShareCodeLink() {
  const text = $('#shareLink').text();
  try {
    await navigator.clipboard.writeText(text);
    toggleAlertMsgModal('link copied.',1);
  } catch (error) {
    toggleAlertMsgModal('Error while copying link.',2);
    console.error('Error while copying link: ', error);
  }
}

function getStepwiseUserInput() {
  let counter = 0;
  const stepwiseUserInputArray = [];

  while (1) {
    const txtOutputObj = $(`#txtOutput${counter}`);
    if (txtOutputObj.length) {
      stepwiseUserInputArray.push(txtOutputObj.val());
      counter += 1;
    } else break;
  }

  return stepwiseUserInputArray;
}

function onResetCodeClick(event) {
  event.preventDefault();

  const message = 'Are you sure you want to reset back to the default code template? If you click yes, you will lose your current code!';
  toggleAlertModal({ message }, (val) => {
    if (val) {
      if (question.type == '9') {
        webEditorContent = JSON.parse(JSON.stringify(defaultWebEditorContent));
        editor.setValue(webEditorContent[currentTab]);
        return;
      }

      editor.setValue(defaultCode[$('#progLang').val()]);
    }
  });
}

function editorHeightSet() {
  console.log("Head", question.showHead, "tail", question.showTail)
  if($('#consoleBox').hasClass('d-none')) {
      if(!question.showHead && !question.showTail) {
        $(".output_code_section").css('height', '');
        $(".attempted_code_area").css('height', '');
        $(".CodeMirror.cm-s-default").css("height", "calc(100vh - 150px)");
      } else {
          $(".output_code_section").css('height', 'calc(100vh - 110px)');
          $(".attempted_code_area").css('height', 'calc(100vh - 150px)')
          $(".CodeMirror.cm-s-default").css("height", "auto");
          let headHeight = parseInt($("#txtCodeHead").next().outerHeight()) || 0;
          let tailHeight = parseInt($("#txtCodeTail").next().outerHeight()) || 0;
          console.log('head height: ', headHeight, ' tail height: ', tailHeight)
          $('.CodeMirror.cm-s-default .CodeMirror-scroll').css({ "min-height": `calc(100vh - 160px - ${headHeight}px - ${tailHeight}px)` });
          $(".CodeMirror.cm-s-default .CodeMirror-scroll").css("padding-bottom", "70px");
      }
  }else {
      if(!question.showHead && !question.showTail) {
        $(".output_code_section").css('height', '');
        $(".attempted_code_area").css('height', '');
        $(".CodeMirror.cm-s-default").css("height", "calc(100vh - 103px - (50vh - 18px))");
      } else {
          $(".output_code_section").css('height', 'calc(100vh - 62px - (50vh - 18px))');
          $(".attempted_code_area").css('height', 'calc(100vh - 103px - (50vh - 18px))')
          $(".CodeMirror.cm-s-default").css('height', 'auto');
          $('.CodeMirror.cm-s-default .CodeMirror-scroll').css({ "min-height": 'inherit' });
      }
  }
}

function handleFullScreenChange() {
  if (!document.fullscreenElement
    && !document.webkitIsFullScreen
    && !document.mozFullScreen
    && !document.msFullscreenElement
  ) {
    $('#hideInType5').css({ height: '', margin: '' });
    $("#fullscreenbtn").attr("src","/Questions/img/expand(2).png");
    $('.CodeMirror.cm-s-default').removeClass('fullscreenEditorHeight');
    $('.CodeMirror.cm-s-default').removeClass('isFullScreen');
    $("#fullscreenbtn").parent().attr("data-customtooltip","full screen");
    editorHeightSet();
  }
}

function fullScreenEditor() {
  const elem = document.getElementById('fullscreen');
  if (window.innerHeight == screen.height || document.fullscreen) {
    $("#fullscreenbtn").attr("src","/Questions/img/expand(2).png");
    //$("#fullscreenbtn").attr("title","full screen");
    $("#fullscreenbtn").parent().attr("data-customtooltip","full screen");
    $('#hideInType5').css({ height: '', margin: '' });
    $('.CodeMirror.cm-s-default').removeClass('fullscreenEditorHeight');
    $('.CodeMirror.cm-s-default').removeClass('isFullScreen');
    if (document.exitFullscreen) {
      document.exitFullscreen();
    } else if (document.mozCancelFullScreen) {
      /* Firefox */
      document.mozCancelFullScreen();
    } else if (document.webkitExitFullscreen) {
      /* Chrome, Safari and Opera */
      document.webkitExitFullscreen();
    } else if (document.msExitFullscreen) {
      /* IE/Edge */
      document.msExitFullscreen();
    }
    editorHeightSet()
  } else {
    $("#fullscreenbtn").attr("src","/icons/exit-full-screen-2.svg");
    //$("#fullscreenbtn").attr("title","exit full screen");
    $("#fullscreenbtn").parent().attr("data-customtooltip","exit full screen");
    $('#hideInType5').css({ height: `${screen.innerHeight}`, margin: '0' });
    $('.CodeMirror.cm-s-default').addClass('isFullScreen');

    // set full screen editor height
    if(!question.showHead && !question.showTail) {
      $(".output_code_section").css('height', 'calc(100vh - 40px)');
      $(".attempted_code_area").css('height', 'calc(100vh - 40px)');
      $('.CodeMirror.cm-s-default').addClass('fullscreenEditorHeight');
    } else {
      $(".output_code_section").css('height', 'calc(100vh - 40px)');
      $(".attempted_code_area").css('height', 'calc(100vh - 40px)');
      $(".CodeMirror.cm-s-default").css('height', 'auto');
      let headHeight = parseInt($("#txtCodeHead").next().outerHeight()) || 0;
      let tailHeight = parseInt($("#txtCodeTail").next().outerHeight()) || 0;
      console.log('head height: ', headHeight, ' tail height: ', tailHeight)
      $('.CodeMirror.cm-s-default .CodeMirror-scroll').css({ "min-height": `calc(100vh - 60px - ${headHeight}px - ${tailHeight}px)` });
    }

    if (elem.requestFullscreen) {
      elem.requestFullscreen();
    } else if (elem.mozRequestFullScreen) {
      /* Firefox */
      elem.mozRequestFullScreen();
    } else if (elem.webkitRequestFullscreen) {
      /* Chrome, Safari and Opera */
      elem.webkitRequestFullscreen();
    } else if (elem.msRequestFullscreen) {
      /* IE/Edge */
      elem.msRequestFullscreen();
    }
  }
}

function previewInIframe() {

  if(!session.userId){
    webEditorContent[currentTab] = editor.getValue().trim();
    let tempDataForLoginWeb = {
        html:webEditorContent.html,
        css:webEditorContent.css,
        js:webEditorContent.js,
        quesId:`${question._id}`
    }
    localStorage.removeItem('tempDataForLoginWeb');
    localStorage.setItem('tempDataForLoginWeb',JSON.stringify(tempDataForLoginWeb));
    let url = window.location.href.replace(/\+/g,'%2B');
    let isCourseId = new URL(window.location.href).searchParams.get('courseId');
    if(isCourseId){
        toggleLoginForm('/',`/attempt/attemptquestion/${isCourseId}/${question._id}`);
    }else{
        toggleLoginForm('/',`${url}?type=2`);
    }
    return;
  }

  const frame = $('#html-frame');
  webEditorContent[currentTab] = editor.getValue().trim();

  const browserTemplate = `
    <!DOCTYPE html>
    <html>
        <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
        <script type="text/babel">
          let intervalId;
          function checkIframeLoaded() {
            if (document.readyState === "complete") {
              clearInterval(intervalId);

              window.parent.postMessage(JSON.stringify({ loaded: true }));
            }
          }
          intervalId = setInterval(checkIframeLoaded, 100);
        </script>
        ${isReactQuestion ? `
            <script crossorigin src=\"https://unpkg.com/react@17/umd/react.production.min.js\"><\/script>
            <script crossorigin src=\"https://unpkg.com/react-dom@17/umd/react-dom.production.min.js\"><\/script>
          ` : ''}
        <style>
          ::-webkit-scrollbar {
            width: 7px;
            height: 7px;
          }
        
          ::-webkit-scrollbar-track {
            border-radius: 20px;
          }

          ::-webkit-scrollbar-thumb {
            background: #e5e5e5;
            border-radius: 8px;
          }

          ::-webkit-scrollbar-thumb:hover {
            background: #8e8e8e;
          }
          ${webEditorContent.css}
        </style>
        <script></script>
      </head>
      <body>
        ${webEditorContent.html}
        <script></script>
        <script type="text/babel">
        ${webEditorContent.js}
        </script>
        <script></script>
        <script type="text/babel">
          ${isReactQuestion ? webEditorContent.reactRendererCode : ''}
        </script>
        <script></script>
      </body>
    </html>
  `;

  frame.attr('srcdoc', browserTemplate);
}

function changeTitleColor() {
  $('#tabsTitle div').css('background', '#FAFAFA');
  $(`#tabsTitle  #${currentTab}`).css('background', '#dfdfdf');
}

function changeTabs(e) {
  newCurrentTab = e.target.id;
  webEditorContent[currentTab] = editor.getValue().trim();
  currentTab = newCurrentTab;

  if (currentTab == 'js') {
    editor.setOption('mode', 'javascript');
  } else if (currentTab == 'html') {
    editor.setOption('mode', 'htmlmixed');
  } else if (currentTab == 'css') {
    editor.setOption('mode', 'css');
  }

  changeTitleColor();

  editor.setValue(webEditorContent[currentTab]);
  editor.clearHistory();
  editor.focus();
}

function clearMCQSelection() {
  $('.imgMCQ').remove();
  $('.mcq-result-text').remove();
  $('input[type="radio"].qus_choices').prop('checked', false);
}


function errorHandler(data) {
  $('#executeProgram').prop('disabled', false);
  if (question.type == 5 || question.type == 10) {
    $('#executeProgram').prop('value', 'Submit');
  } else {
    $('#executeProgram').prop('value', 'run');
  }
  $('#executeMCQ').prop('disabled', false);
  $('#executeMCQ').prop('value', 'Submit');

  if (question.type == 10 && data) {
    toggleAlertMsgModal(`ERROR : ${data} \n please make sure your project run link is correct!`,2);
  } else if(question.type == 4 && question.files && question.files.length){
    if(data && data.indexOf('no such file or directory')) {
      toggleAlertMsgModal('File not found',2);
    }
  } else {
    toggleAlertMsgModal( typeof(data) == "string" ? data : 'connection error! please check you internet.',2);
  }

  console.error(`ERROR : ${data}`);
}

async function synchronizeAsyncSeries(asyncSeries) {
  for (const x of asyncSeries) {
    await x();
  }
}

async function runWebTests(shouldFail) {
  /* utility for preview frame document */
  const previewFrameWindow = $('.web-browser-container')[0].contentWindow;
  const previewFrameDocument = $('.web-browser-container')[0].contentWindow.document;
  const previewFrameSleep = async (duration) => {
    return new Promise((resolve) => {
      setTimeout(() => {
        resolve();
      }, duration);
    });
  };
  /* utility for preview frame document */

  const testCases = question.questionTypeWeb && question.questionTypeWeb.testCase
    ? question.questionTypeWeb.testCase
    : [];
  const testResults = new Array(testCases.length).fill(false);

  if (!shouldFail) {
    await synchronizeAsyncSeries(testCases.map((testCase, index) => async () => {
      let result;
      try {
        result = await eval(testCase.evaluator);
      } catch (error) {
        console.error(error);
        result = false;
      }
      testResults[index] = Boolean(result);
    }));
  }

  // for preview page:
  if (!container) {
    return compileHandler({
      outputArray: testResults,
    });
  }

  const payload = {
    questionId: question._id,
    isCompleted,
    snapshots: [],
    sid: sessionStorage.getItem('sid'),
    courseFiles: [],
    userAnswerId,
    parentId: session.parentId,
    quesType: question.type,
    courseId,
    html: webEditorContent.html,
    css: webEditorContent.css,
    js: webEditorContent.js,
    testResults,
  };

  if (socket.connected) {
    socket.emit('compile', payload);
  } else {
    console.log('connection error!');
  }
}

function onIframeLoaded(event) {
  if(event && event.data && event.data == '{"loaded":true}'){
    window.removeEventListener('message', onIframeLoaded);
  
    clearTimeout(webTestsWarningTimeout);
    clearTimeout(webTestsFailTimeout);
  
    try {
      if (event && event.data) {
        console.log('herreeeee');
        const data = JSON.parse(event.data);
        if (data.loaded) {
          runWebTests();
        }
      } else {
        throw new Error('web tests must fail!');
      }
    } catch (e) {
      console.error(e);
  
      runWebTests(true);
    }
  }
}

async function onExecuteClick(event) {
  event.preventDefault();

  if(!session.userId){
    if(question.type == '4') {
        let langId = $('#progLang').val();
        let code = editor.getValue().trim();
        let quesId = `${question._id}`
        let tempDataForLoginCode = {langId,code,quesId}
        localStorage.removeItem('tempDataForLoginCode');
        localStorage.setItem('tempDataForLoginCode',JSON.stringify(tempDataForLoginCode));
    }else if(question.type == '5'){
        let counter = 0;
        let tempDataForLoginMQ = {}
        tempDataForLoginMQ.quesId = `${question._id}`;
        tempDataForLoginMQ.data = []

        while (1) {
            let txtOutputObj = $('#txtOutput' + counter);
            if (txtOutputObj.length) {
                tempDataForLoginMQ.data.push($('#txtOutput' + counter).val().trim());
                counter += 1;
            }
            else break;
        }
        localStorage.removeItem('tempDataForLoginMQ');
        localStorage.setItem('tempDataForLoginMQ',JSON.stringify(tempDataForLoginMQ));
    }else if(question.type == '9'){
        webEditorContent[currentTab] = editor.getValue().trim();
        let tempDataForLoginWeb = {
            html:webEditorContent.html,
            css:webEditorContent.css,
            js:webEditorContent.js,
            quesId:`${question._id}`
        }
        localStorage.removeItem('tempDataForLoginWeb');
        localStorage.setItem('tempDataForLoginWeb',JSON.stringify(tempDataForLoginWeb));
    }
    let url = window.location.href.replace(/\+/g,'%2B');
    let isCourseId = new URL(window.location.href).searchParams.get('courseId');
    if(isCourseId){
        toggleLoginForm('/',`/attempt/attemptquestion/${isCourseId}/${question._id}`);
    }else{
        toggleLoginForm('/',`${url}?type=2`);
    }
    return;
  }


  if(question.type === '4' && $('#customInput').is(':checked')){
    
    // check custom input size. is it greater than 2MB if yes then stop

    if(($('#stdin').val().length / 1000) > 2000){ // give size in KB
      toggleAlertMsgModal('Custom input size greater than 2MB is not allowed',2);
      return;
    }
  }

  if ($(this).prop('disabled')) {
    return;
  }

  $(this).prop('disabled', true);
  if (question.type == 5 || question.type == 10) {
    $(this).prop('value', 'Submitting');
  } else {
    $(this).prop('value', 'running');
  }

  let payload = {
    questionId: question._id,
    isCompleted,
    snapshots,
    sid: sessionStorage.getItem('sid'),
    courseFiles: courseContentFiles,
    userAnswerId,
    parentId: session.parentId,
    quesType: question.type,
    courseId,
  };

  if (question.type == 10) {
    const projectLink = document.getElementById('project-link').value;

    if (!(projectLink && projectLink.trim())) {
      toggleAlertMsgModal('Project Link can not be empty!',2);

      resetButtons();

      return;
    }

    payload = {
      ...payload,
      submitProjectLink: projectLink,
    };
  }

  /**
   * ????
   */
  if (question.type === '3' || question.type === '4') {
    saveSnapshot();
  }

  if (question.type === '4') {
    const code = editor ? editor.getValue().trim().replace(/^\s*$[\n\r]{1,}/gm, '') : '';
    const isCustomInput = $('#customInput').is(':checked');
    const languageId = $('#progLang').val();

    sessionStorage.setItem(`${session.userId}:${question._id}:${courseId}`, JSON.stringify({ code, lang: languageId }));

    payload = {
      ...payload,
      language: languageId,
      code,
      stdin: $('#customInput').is(':checked') ? $('#stdin').val().trim() : '',
      isCustomInput,
      isStepwise: false,
      executionType,
    };

    let hasCompiled = false;

    if (!isCustomInput
      && cachedResult
      && Object.prototype.hasOwnProperty.call(cachedResult, languageId)
      && cachedResult[languageId].length
    ) {
      const languageCodeResultArray = cachedResult[languageId];
      languageCodeResultArray.forEach((compileResult) => {
        if (code === compileResult.code.trim()) {
          hasCompiled = true;
          compileResult.count += 1;
          addDataToCache(compileResult.result, languageId);
          compileHandler(compileResult.result);
          if (session && (session.role == '1' || session.role == '2')) {
            if (socket) {
              socket.emit('save_question_attempt', { payload, result: compileResult.result });
            } else {
              console.log('connection error!');
              event.preventDefault();
            }
          }
        }
      });
    }
    if (hasCompiled) {
      return;
    }
  }

  if (question.type == 5 && !(question.questionTypeCoding && question.questionTypeCoding.isTraceTable)) {
    payload = {
      ...payload,
      isStepwise: true,
      stepwiseUserInput: getStepwiseUserInput(),
      executionType, // ???
    };
  }

  if(question.type == 5 && question.questionTypeCoding && question.questionTypeCoding.isTraceTable){
    payload = {
      ...payload,
      isStepwise: true,
      stepwiseUserInput: [convertTableToText()],
      executionType, // ???
      traceTableTestCaseId: question.questionTypeCoding.testCase[traceTableTestCaseIndex]._id,
      traceTableTestCaseIndex,
    }
  }

  snapshots = [];
  clearInterval(snapshotIntervalId);
  snapshotIntervalId = null;

  if (question.type == '9') {
    $('[id*="test-case-"] img').attr('src', '/icons/spinner.svg').attr('alt', 'running');
    editor.setOption("readOnly", true)

    $('#preview').click();

    if (isReactQuestion) {
      webEditorContent[currentTab] = editor.getValue().trim();

      delete payload.snapshots;
      delete payload.courseFiles;
      delete payload.quesType;
      // delete payload.courseId;

      payload = {
        ...payload,
        html: webEditorContent.html,
        css: webEditorContent.css,
        js: webEditorContent.js,
        language: 2,
        code: '', // ???
        stdin: '', // ???
        isInvalidAttempt: !Boolean(container),
      };
    } else {
      window.addEventListener('message', onIframeLoaded, false);

      webTestsWarningTimeout = setTimeout(() => {
        toggleAlertMsgModal('Preview browser content taking too long to load, tests might fail or show incorrect results.',2);
      }, 15000);

      webTestsFailTimeout = setTimeout(() => {
        onIframeLoaded();
      }, 20000);

      return;
    }
  }
  if (question.type === '4') {
    return handleCodingQuestionCompilation(payload);
  }
  if (socket.connected) {
    socket.emit('compile', payload);
  } else {
    console.log('connection error!');
  }
}

async function handleCodingQuestionCompilation(payload) {
  if (window?.api?.compile) {
    payload.question_for_compilation = {
      activityIds: question.activityIds,
      askconf: question.askconf,
      difficultyLevel: question.difficultyLevel,
      executionTime: question.executionTime,
      questionTypeCoding: question.questionTypeCoding,
      score: question.score,
    };
    delete payload.question_for_compilation.text;
    payload.course_for_compilation = courseObj;
    const response = await window.api.compile(payload);
    delete payload.question_for_compilation;
    delete payload.course_for_compilation;
    payload.obj = response;
  }
  socket.emit('compile', payload);
}

function addDataToCache(output, langCode) {
  const obj = {
    code: editor.getValue().replace(/^\s*$[\n\r]{1,}/gm, ''), // ???
    result: output,
    count: 1,
  };

  if (Object.prototype.hasOwnProperty.call(cachedResult, langCode)) {
    const languageCodeResultObj = cachedResult[langCode];
    if (languageCodeResultObj.length === 3) {
      languageCodeResultObj.splice(0, 1);
    }

    languageCodeResultObj.push(obj);
  } else {
    cachedResult[langCode] = [];
    cachedResult[langCode].push(obj);
  }
}

const resetButtons = () => {
  $('#executeProgram').prop('disabled', false);
  if (question.type == 5 || question.type == 10) {
    $('#executeProgram').prop('value', 'Submit');
  } else {
    $('#executeProgram').prop('value', 'run');
  }
};

const showConsoleBox = () => {
  $('#consoleBox').removeClass('d-none');
  $('#fullscreen').css('height', 'calc(100vh - 110px - (50vh - 66px))');
  if (question.type == 9) {
    $('.web-components-container .CodeMirror').css('height', 'calc(100vh - 103px - (50vh - 18px))');
  }else if(question.type == 4) {
    if(!question.showHead && !question.showTail) {
      $(".output_code_section").css('overflow', '');
      $(".CodeMirror.cm-s-default").css('height', 'calc(100vh - 103px - (50vh - 18px))');
    } else {
      $(".output_code_section").css('height', 'calc(100vh - 62px - (50vh - 18px))');
      $(".attempted_code_area").css('height', 'calc(100vh - 103px - (50vh - 18px))')
      $(".CodeMirror.cm-s-default").css('height', 'auto');
      $('.CodeMirror.cm-s-default .CodeMirror-scroll').css({ "min-height": 'calc(100vh - 103px - (50vh - 18px))' });
    }
  }

  // select first test case if not selected
  if (!$('#testCaseBox').hasClass('d-none')) {
    if(question.questionTypeCoding && question.questionTypeCoding.executionType == '2' && sampleTestCaseCount > 0){
      // if sample testcase and executionType result only
      $('.test-case-container .showTestCase')[0].click()
    }else{
      $('#test-case-1 a').click();
    }

  }
  $("#fa-toggle-down-console").addClass("d-none");
  $("#fa-toggle-up-console").removeClass("d-none");

  if(question.type == 4 && question.questionTypeCoding && question.questionTypeCoding.testCase && question.questionTypeCoding.testCase.length <= 0){
    changeConsole(3)
    $("#testCaseBtn").hide()
  }
};

const hideConsoleBox = () => {
  $('#consoleBox').addClass('d-none');
  $('#fullscreen').css('height', 'calc(100vh - 110px)');
  if (question.type == 9) {
    $('.web-components-container .CodeMirror').css('height', 'calc(100vh - 150px)');
  }else if(question.type == 4) {
    if(!question.showHead && !question.showTail){
      $(".output_code_section").css('overflow', 'auto');
      $(".CodeMirror.cm-s-default").css('height', 'calc(100vh - 150px)');
    } else {
      $(".output_code_section").css('height', 'calc(100vh - 110px)');
      $(".attempted_code_area").css('height', 'calc(100vh - 150px)')
      $(".CodeMirror.cm-s-default").css("height", "auto");
      let headHeight = parseInt($("#txtCodeHead").next().outerHeight()) || 0;
      let tailHeight = parseInt($("#txtCodeTail").next().outerHeight()) || 0;
      console.log('head height: ', headHeight, ' tail height: ', tailHeight)
      $('.CodeMirror.cm-s-default .CodeMirror-scroll').css({ "min-height": `calc(100vh - 160px - ${headHeight}px - ${tailHeight}px)` });
    }
  }
  $("#fa-toggle-down-console").removeClass("d-none");
  $("#fa-toggle-up-console").addClass("d-none");
};

const toggleConsoleBox = () => {
  if ($('#consoleBox').hasClass('d-none')) {
    showConsoleBox();
  } else {
    hideConsoleBox();
  }
};

const changeConsole = (consoleNumber) => {

  if($('#customInput').is(':checked') && consoleNumber == 1){
    return;
  }

  $('.console-tabs').removeClass('selected');
  if (consoleNumber == 1) {
    // testCaseBox
    $('#testCaseBtn').addClass('selected');

    $('#testCaseBox').removeClass('d-none');
    $('#customInputBox').addClass('d-none');
    $('#errorBox').addClass('d-none');

    // select first default if not selected
    if (!$('.test-case-container').children().hasClass('selected')) {

      if(question.questionTypeCoding && question.questionTypeCoding.executionType == '2' && sampleTestCaseCount > 0){
        // if sample testcase and executionType result only
        $('.test-case-container .showTestCase')[0].click()
      }else{
        $('#test-case-1 a').click();
      }
    }
    // uncheck custominput box
    // $('#customInput').prop('checked', false);
  } else if (consoleNumber == 2) {
    // customInputBox
    $('#customInputBtn').addClass('selected');

    $('#customInputBox').removeClass('d-none');
    $('#testCaseBox').addClass('d-none');
    $('#errorBox').addClass('d-none');

    // check custom input checkbox
    // $('#customInput').prop('checked', true);
  } else if (consoleNumber == 3) {
    // errorBox
    $('#consoleBtn').addClass('selected');

    $('#errorBox').removeClass('d-none');
    $('#customInputBox').addClass('d-none');
    $('#testCaseBox').addClass('d-none');
  }
};

const wrondTdHighlight = (expectedAns) => {
  let ans2DArray = [];
  if(expectedAns) {
    let rows = expectedAns.split(rowSeprator);
    for(let i = 1; i < rows.length; i++) {
      let cols = rows[i].split(colSeprator);
      ans2DArray.push(cols);
    }
  }

  $("#previewTable tbody tr").each(function(i){          
      $(this).find('td').each(function(j){
        if($(this).find('input')[0] === undefined) {
          return;
        }
        let tdValue = $(this).find('input').val().trim();
        // console.log('Opt:',tdValue, 'Exp:', ans2DArray[i][j])
        if(ans2DArray && ans2DArray[i] && ans2DArray[i][j] != tdValue)
          $(this).find('input').css('border','1px solid red');
      })
  })
}

const appendCompileData = (data) => {
  if (question.type == 4) {
    let totalTestCasePassed=0;
    if (data.errors) {
      $('#txtError').val(data.errors);
      changeConsole(3);
    } else if (data.outputArray) {
      if ($('#customInput').is(':checked')) {
        $('#txtError').val(data.outputArray[0].userOutput.trim());
        changeConsole(3);
        return;
      }
      // if only compile question
      if (question.questionTypeCoding.executionType == 1) {
        $('#txtError').val(data.outputArray);
        return;
      }
      // if only compile question
      data.outputArray.forEach((val, ind) => {
        $(`#test-case-${ind + 1}`).find('.yOutput').text(val.userOutput);
        // console.log($(`#test-case-${ind + 1}`).find('.yOutput'))
        if (val.testCasePassed) {
          $(`#test-case-${ind + 1}`).find('img').attr('src', '/icons/check1.svg');
          totalTestCasePassed++;
        } else {
          $(`#test-case-${ind + 1}`).find('img').attr('src', '/icons/interface.svg');
        }
      });
      changeConsole(1);
      $("#totalTestCaseResultContainer p").text(`Test case passed ${totalTestCasePassed}/${data.outputArray.length}`)
    }
  } else if (question.type == 9 && (data.userOutputArray || data.outputArray)) {
    const resultArray = data.outputArray || data.userOutputArray.map(el => el.testCasePassed);

    resultArray.forEach((result, index) => {
      if (result) {
        $(`#test-case-${index + 1} img`).attr('src', '/icons/check1.svg').attr('alt', 'passed');
      } else {
        $(`#test-case-${index + 1} img`).attr('src', '/icons/interface.svg').attr('alt', 'failed');
      }
    });

    if(!userAttempt){
      editor.setOption("readOnly", false)
    }
    
  } else if (question.type == 10) {
    const testCasesStatus = data.testCasePassed && data.totalTestCases ? `${data.testCasePassed}/${data.totalTestCases}` : '';
    const message = `Project submission successful! ${testCasesStatus ? `\n Result: ${testCasesStatus}` : ''}`;

    toggleAlertMsgModal(message,1);
  } else if (question.type == 5) {
    if(question.questionTypeCoding.isTraceTable){
      // console.log('after Result: ', data);
      $("#previewTable").find('input').each(function(){
        $(this).css('border', '1px solid #d1d1d1');
      })

      if(data.testCasePassed > 0){
        $("#traceResult").attr('src','/icons/check1.svg');
      }else{
        $("#traceResult").attr('src','/icons/interface.svg');

        // wrond td answer highlight with red color
        let expectedAns = data && data.testCase && data.testCase[0] && data.testCase[0].codeprogexpectedoutput || "";
        if(expectedAns) wrondTdHighlight(expectedAns);
        
      }

      // preview with answer for trace table question
      if(data && data.testCase && data.testCase[0] && data.testCase[0].codeprogexpectedoutput) {
        let questionData = '';
        (question?.questionTypeCoding?.testCase ?? []).forEach((element) => {
          if (element._id == data.testCase[0]._id) {
            questionData = element.codeprogexpectedoutput;
          }
        })
        if (questionData) {
          toSend = populateShowContentOverUserAttempt(questionData, data.testCase[0].codeprogexpectedoutput)
          convertTextToTable(toSend, true, true);
        } else {
          convertTextToTable(data.testCase[0].codeprogexpectedoutput, true, true);
        }

      }
      
      return;
    }
    if (data.userOutputArray) {
      data.userOutputArray.forEach((result, index) => {
        $(`#dvResult${index}`).show();
        if (result.testCasePassed) {
          $(`#imgRes${index}`).attr('src', '/icons/check1.svg');
        } else {
          $(`#imgRes${index}`).attr('src', '/icons/interface.svg');
        }
      });
    } else if ((question.questionTypeCoding && question.questionTypeCoding.executionType && question.questionTypeCoding.executionType == 3 && data.testCase && data.testCase.length > 0) || session.role != 1) {
      data.testCase.forEach((mqOutput, index) => {
        if ((mqOutput.codeprogexpectedoutput || '').trim() === (data.outputArray[index] || '').trim()) {
          // test case passed
          $(`#dvResult${index}`).show();
          $(`#dvExpectedoutput${index}`).show();
          $(`#txtExpOutput${index}`).val(mqOutput.codeprogexpectedoutput);
          $(`#imgRes${index}`).attr('src', '/icons/check1.svg');
        } else {
          // test case failed
          $(`#dvResult${index}`).show();
          $(`#dvExpectedoutput${index}`).show();
          $(`#txtExpOutput${index}`).val(mqOutput.codeprogexpectedoutput);
          $(`#imgRes${index}`).attr('src', '/icons/interface.svg');
        }
      });
    }
  }
};

function compileHandler(data) {
  if(session && session.role != 1) console.log('compile result ----> ', data);
  resetButtons();
  appendCompileData(data);
  if((question.type == 9 && question.questionTypeWeb.testCase.length > 0) || question.type == 4){
    showConsoleBox();
  }
  // if(question.type == 9 && !userAttempt){
  //   editor.setOption("readOnly", false);
  // }
}

