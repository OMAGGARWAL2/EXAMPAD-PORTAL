});

const showTabTracetable = (e, index, testcaseId) => {
  if($(e).hasClass('active')) return;
  
  if(traceTableTestcaseMap.has(testcaseId)) {
    traceTableTestCaseIndex = +index;
    let testcase = traceTableTestcaseMap.get(testcaseId);
    console.log("testcase: ", testcase);

    convertTextToTable(testcase.tracetableText || '');
    $("#resultTable").html('');
    $("#traceResult").attr('src', '');
    $('#tracetableQuesDesc').remove();
    let tracetableDescription = testcase.tracetableDescription || '';
    tracetableDescription = tracetableDescription.replace(/>/g, "&gt;")
    tracetableDescription = tracetableDescription.replace(/</g, "&lt;")
    $("#question-description").append(`<div id='tracetableQuesDesc'><hr/><h5>Question:</h5> <p>${tracetableDescription || ''}</p></div>`);
  }else {
    toggleAlertMsgModal('Testcase not found', 2);
  }
}

const convertTableToText = () => {
  let finalStr = ``;

  // table head append
  finalStr+=question.questionTypeCoding.testCase[traceTableTestCaseIndex].codeprogexpectedoutput.split(rowSeprator)[0];

  $("#previewTable tbody tr").each((index,row) => {
    finalStr+=rowSeprator
    $(row).find('td input').each((inputIndex, inputVal) => {
      finalStr+=`${$(inputVal).val()}`;
      if(inputIndex+1 != $(row).find('td input').length) finalStr+=`${colSeprator}`
    })
  });
  
  // finalStr=finalStr.substring(0,finalStr.length-1);

  return finalStr;
}

function populateShowContentOverUserAttempt(questionData, userAttempt) {
  const questionRows = questionData.split('\n');
  const populateArray = []
  questionRows.forEach((rows, i) => {
    const cols = rows.split(',');
    cols.forEach((element, j) => {
      const toPopulate = canShow(element);
      if (toPopulate) {
        populateArray.push({
          row: i,
          col: j,
          content: element,
        })
      }
    })
  });
  let userAttemptArray = userAttempt.split('\n');
  userAttemptArray = userAttemptArray.map((element) => {
    return element.split(',');
  });
  populateArray.forEach((element) => {
    if (userAttemptArray?.[element.row]?.[element.col]) {
      userAttemptArray[element.row][element.col] = element.content;
    }
  })
  return userAttemptArray.reduce((result, current, index) => {
    if (index !== 0) {
      result += '\n';
    }
    result += current.join(',');
    return result;
  }, '');
}

const canShow = (item) => {
  if (item.startsWith('&lt;show&gt;') && item.endsWith('&lt;/show&gt;')) {
    item = item.replace('&lt;show&gt;', '');
    item = item.replace('&lt;/show&gt;', '');
    return item;
  }
  if (item.startsWith('<show>') && item.endsWith('</show>')) {
    item = item.replace('<show>', '');
    item = item.replace('</show>', '');
    return item;
  }
  return false;
}


const convertTextToTable = (text, isAttempt = false, isShowExpectedOP = false, isReturn = false) => {
  debugger;
  let table = `
      <table class="table table-sm">
  `;
  if(text) {
    text = text.replace(/>/g, "&gt;")
    text = text.replace(/</g, "&lt;")
  }

  let rows = text.split(rowSeprator);

  // create table head
  table+=`<thead><tr>`;
  let tableHead = rows[0].split(colSeprator);
  tableHead.forEach((tHead) => {
      table+=`
          <th scope="col">${tHead}</th>
      `;
  });
  table+=`</tr></thead>`;
  // create table head

  // create table
  table+=`<tbody>`;
  for(let row=1;row<rows.length;row++){
      let col = rows[row].split(colSeprator);
      table+=`<tr>`;
          col.forEach((colName) => {
            const item = canShow(colName);
            if (item){
              table+=`<td><input class="table-item-show" type="text" disabled value="${item}" /></td>`
            } else {
              table+=`<td>
              <input type="text"  ${isAttempt? `disabled value="${colName}"` :''}/>
            </td>`
            }
            
          });
      table+=`</tr>`;
  }
  table+=`</tbody></table>`;

  if(isReturn)   return table;
  // create table
  if(!isShowExpectedOP) {
    $("#previewTable").html(table);
  } else if(isShowExpectedOP) {
    $("#resultTable").html('');
    $("#resultTable").append(`<div style="height: auto;" class="row mb-2">
      <div class="col-12 pt-0 pl-3" id="span-choose-any-one">
          <span>Solution</span>
          <div id="div-choose-any-one-underline"></div>
      </div>
    </div>`);
    $("#resultTable").append(`<div class='tracetableContainer'>${table}</div>`);
  }
}


