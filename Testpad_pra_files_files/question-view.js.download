let addingToFavourites = false;
let removingFromFavourites = false;

async function removeFromFavourites() {
  if (removingFromFavourites) {
    return;
  }

  try {
    await new Promise((resolve, reject) => {
      toggleAlertModal({ message: 'do you really want to remove this from favourites?' }, (isOk) => {
        if (isOk) {
          resolve();
        } else {
          reject();
        }
      });
    });

    try {
      removingFromFavourites = true;

      const response = await fetch('/api/favourites/remove', {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          resourceId: question._id,
        }),
      });

      if(response.redirected) {
        console.log('Before Get response redirect', response);
        if(response.url && response.url.indexOf('login') > -1) location.reload();
        else window.location = `${response.url}`;
      } 

      const data = await response.json();
      if (data.error || !data.success) {
        throw new Error(data.error || 'Internal server error');
      }

      $('#removeFromFavourites').hide();
      $('#addToFavourites').show();
    } catch (error) {
      console.error(error);

      toggleAlertMsgModal(error,2);
    } finally {
      removingFromFavourites = false;
    }
  } catch (e) {}
}

async function addToFavourites() {
  if (addingToFavourites) {
    return;
  }

  try {
    addingToFavourites = true;

    const response = await fetch('/api/favourites/add', {
      method: 'POST',
      headers: {
        Accept: 'application/json',
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        resourceId: question._id,
        resourceType: 1,
        courseId,
      }),
    });

    if(response.redirected) {
      console.log('Before Get response redirect', response);
      if(response.url && response.url.indexOf('login') > -1) location.reload();
      else window.location = `${response.url}`;
    } 

    const data = await response.json();
    if (data.error || !data.success) {
      throw new Error(data.error || 'Internal server error');
    }

    $('#addToFavourites').hide();
    $('#removeFromFavourites').show();
  } catch (error) {
    console.error(error);

    toggleAlertMsgModal(error,2);
  } finally {
    addingToFavourites = false;
  }
}

function changeIframeSolutionLink(tutorialLink) {
  if (tutorialLink) {
    document.getElementById('solution-iframe').src = `${tutorialLink}?solution=true`;

    // hide code editor part and make solution tab full width
    if(window.matchMedia( "(min-width: 767px)" ).matches){
    $('#code-area').hide();
    $('#consoleBox').hide();
    $('#scolll').css('width', '100%');
    $('#consoleBox').css('width', '100%');
    $('#console-option').css('width', '100%');
    }


    // 
    $("#question-container").css({'width':'95%','padding':'0','margin':'0px', 'overflow': ''})
  }
}
const closeIframeSolution = ()=>{
  if(question && question.type == 4 && window.matchMedia( "(min-width: 767px)" ).matches){

    $('#code-area').show();
    $('#consoleBox').show();
    $('#scolll').css('width', `40%`);
    $('#code-area').css('width', `60%`);
    $('#consoleBox').css('width', `59.5%`);
    $('#console-option').css('width', `60%`);

    // 
    $("#question-container").css({'padding-right':'15px','padding-left':'15px','margin':'auto','margin-top':'8px'});
  }
}

const startProject = async (projectLink) =>{
  const rawResponse = await fetch(projectLink);
  if(rawResponse.redirected) {
    console.log('Before Get response redirect', rawResponse);
    if(rawResponse.url && rawResponse.url.indexOf('login') > -1) location.reload();
    else window.location = `${rawResponse.url}`;
  } 
  const response = await rawResponse.json();
  console.log(response);
  let runLink = response.userProjectRunLink;
  let editLink = response.userProjectEditLink;
  $("#project-link").val(runLink);
  window.open(editLink,'_blank');
  location.reload()
}
$('#customInput').change(function() {
  if(this.checked) {
    $("#customInputBtn").show()

    if ($('#consoleBox').hasClass('d-none')) {
      showConsoleBox();
    }
    changeConsole(2)

    // testcase btn
    $("#testCaseBtn").attr('data-customtooltip','Disable custom input before running test cases.').css('cursor','not-allowed');

  }else{
    $("#customInputBtn").hide()
    if(question.questionTypeCoding.testCase.length > 0){
      changeConsole(1)
    }else{
      changeConsole(3)
    }

    // testcase btn
    $("#testCaseBtn").removeAttr('data-customtooltip').css('cursor','pointer');

  }
});

const openFeedback = () =>{
  if($('.feedback-ballon').hasClass('feedback-ballon-visible')){
    $('.feedback-ballon').removeClass('feedback-ballon-visible');
  }else{
    $('.feedback-ballon').addClass('feedback-ballon-visible');
  }
  
}

/**
 * 
 * @param {boolean} state 
 * @param {{ testCaseId: string } | undefined} config
 */
const configCloudDownloadButton = (state, config) => {
  $('#cloud-download').attr('testCaseId', '');
  if (state) {
    $('#cloud-download').show();
    $('#cloud-download').attr('testCaseId', config.testCaseId);
  } else {
    $('#cloud-download').hide();
  }
}

const showTestCase = (testcase) =>{
  console.log(testcase);
  if(question.type == 9){
    let description = $(testcase).parent().find('.description-params').text().trim()
    $(".test-cases").removeClass('selected');
    $(testcase).parent().addClass('selected');
    $("#description pre").empty()
    $("#description pre").text(description)
    return;
  }
  const showDownloadbutton = ($(testcase).parent().find('.onCloud'))?.[0]?.checked ?? false;
  let inputParams = $(testcase).parent().find('.input-params').text().trim()
  let expectedParams = $(testcase).parent().find('.expected-params').text().trim()
  let yOutPut = $(testcase).parent().find('.yOutput').text().trim()
  $(".test-cases").removeClass('selected');
  $(testcase).parent().addClass('selected')
  $("#inputParams pre").empty()
  $("#inputParams pre").text(inputParams)

  $("#expectedParams pre").empty()
  $("#expectedParams pre").text(expectedParams)

  if(yOutPut){
    $("#yOutputParams pre").empty()
    $("#yOutputParams pre").text(yOutPut)
  }else{
    $("#yOutputParams pre").empty()
  }
  const testCaseid = testcase.id
  configCloudDownloadButton(showDownloadbutton, { testCaseId: testCaseid });
}

$(document).ready(function () {
  $('.CodeMirror.cm-s-default').css({ height: 'calc(100vh - 150px)' });
  if(question.type == 4 && (question.showHead || question.showTail)) {
    $(".CodeMirror.cm-s-default").css("height", "auto");

    let headHeight = parseInt($("#txtCodeHead").next().outerHeight()) || 0;
    let tailHeight = parseInt($("#txtCodeTail").next().outerHeight()) || 0;
    console.log('head height: ', headHeight, ' tail height: ', tailHeight)
    $('.CodeMirror.cm-s-default .CodeMirror-scroll').css({ "min-height": `calc(100vh - 160px - ${headHeight}px - ${tailHeight}px)` });
  }
})



