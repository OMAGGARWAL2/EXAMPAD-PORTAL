        let ghostbarLeftWidth = ((e.pageX - document.getElementById('scolll').offsetWidth) / document.getElementById('webComponents').offsetWidth) * 100;
  
        let ghostbarRightWidth = 100 - ghostbarLeftWidth - 0.5;
  
        // ghostbarLeftWidth -= 1;
        // ghostbarRightWidth -= 1;
  
        if (ghostbarLeftWidth < 35) {
          $('#webcomponentLeftSide').css('width', '34%');
          $('#output').css('width', '66%');
          $("#output").show();
        } else if (ghostbarRightWidth < 1) {
          if ($('#output').is(':visible') || 1) {
            $('#output').hide();
            $('#webcomponentLeftSide').css('width', '97.5%');
          } else {
            $('#output').show();
            $('#output').css('width', '14%');
            $('#webcomponentLeftSide').css('width', '83%');
          }
        } else {
          $('#output').show();
          $('#webcomponentLeftSide').css('width', `${ghostbarLeftWidth}%`);
          $('#output').css('width', `${ghostbarRightWidth}%`);
        }
  
        // iframe and divider height issue when resize=================================
        if (document.getElementById('changeEditorCodeLang').offsetHeight > 40) {
          $('#html-frame').css({ height: 'calc(100vh - 138px)' });
          $('#webcomponentDivider').css({ height: 'calc(100vh - 80px)' });
        } else {
          $('#html-frame').css({ height: 'calc(100vh - 168px)' });
          $('#webcomponentDivider').css({ height: 'calc(100vh - 110px)' });
        }
        // iframe and divider height issue when resize=================================
      }
    });
  });

  $(document).mouseup((e) => {
    $('.transparent-overlay').addClass('d-none');
    draggingQuestionWebArea = false;
    $('#ghostbar').remove();
    $(document).unbind('mousemove');
  });
}


