function openupdateprojectnamecontainer() {
  document
    .getElementById("projectname-header-container")
    .classList.add("d-none");
  document
    .getElementById("projectname-edit-header-container")
    .classList.remove("d-none");
}

function updateprojectname() {
  // alert(document.getElementById('input-update-projectname').value)
  document.getElementById("header-project-rename").innerHTML =
    document.getElementById("input-update-projectname").value;
  document
    .getElementById("projectname-header-container")
    .classList.remove("d-none");
  document
    .getElementById("projectname-edit-header-container")
    .classList.add("d-none");
}

function openprojectlink() {
  if (
    document
      .getElementById("div-share-link-main-container")
      .classList.item(0) === "d-none"
  ) {
    // open
    document
      .getElementById("div-share-link-main-container")
      .classList.remove("d-none");
    document
      .getElementById("share-link-container")
      .setAttribute("style", "border:none; background-color:#FFEEE5");
    document
      .getElementById("new-link-container")
      .setAttribute("style", "border-left:none;");
    document
      .getElementById("span-share-link")
      .setAttribute("style", "color:#DE6834");
    document.getElementById("icon-share-header-1").classList.add("d-none");
    document.getElementById("icon-share-header-2").classList.remove("d-none");
  } else {
    // close
    document
      .getElementById("div-share-link-main-container")
      .classList.add("d-none");
    document
      .getElementById("share-link-container")
      .setAttribute(
        "style",
        "border-left:1px solid #c1c1c1; background-color:#FFFFF"
      );
    document
      .getElementById("new-link-container")
      .setAttribute("style", "border-left:1px solid #c1c1c1;");
    document
      .getElementById("span-share-link")
      .setAttribute("style", "color:#000");
    document.getElementById("icon-share-header-1").classList.remove("d-none");
    document.getElementById("icon-share-header-2").classList.add("d-none");
  }
}

$(document).ready(() => {
  if (window.innerWidth < 992) {
    if ($("#projectname-header-container").length) {
      $("#startSharingButton").remove();
      $("#collab-user-list-dropdown").remove();
    }
  }

  $("#show-square-dropdown").click(() => {
    if (
      $("#square-dropdown-container").hasClass(
        "square-dropdown-container-visible"
      )
    ) {
      $("#square-dropdown-container").removeClass(
        "square-dropdown-container-visible"
      );
      $("#square-icon-container").css({ background: "none" });
    } else {
      $("#square-dropdown-container").addClass(
        "square-dropdown-container-visible"
      );
      $("#square-icon-container").css({ background: "#F4F4F4" });
    }
  });
  $("#show-square-dropdown-mobile").click(() => {
    if (
      $("#square-dropdown-container").hasClass(
        "square-dropdown-container-visible"
      )
    ) {
      $("#square-dropdown-container").removeClass(
        "square-dropdown-container-visible"
      );
      $("#square-icon-container-mobile").css({ background: "none" });
    } else {
      $("#square-dropdown-container").addClass(
        "square-dropdown-container-visible"
      );
      $("#square-icon-container-mobile").css({ background: "#F4F4F4" });
    }
  });

  //
  $("#btn-question-header").click(() => {
    if (
      $("#rect-dropdown-container").hasClass(
        "square-dropdown-container-visible"
      )
    ) {
      $("#rect-dropdown-container").removeClass(
        "square-dropdown-container-visible"
      );
      $("#rect-icon-container").css({ background: "none" });
    } else {
      $("#rect-dropdown-container").addClass(
        "square-dropdown-container-visible"
      );
      $("#rect-icon-container").css({ background: "#F4F4F4" });
    }
  });

  if (attachLearningModuleSearch) {
    $("#input-search-header").bind("input", function search(e) {
      const value = $(this)
        .val()
        .replace(/[^\w\s\][^,-@]/gi, "");

      $(this).val(value);
    });
  }
});

const openNotificationsContainer = () => {
  $(".notification-dropdown-container").toggleClass(
    "notification-dropdown-container-visible"
  );
};
$(document).mouseup((e) => {
  const container = $("#square-dropdown-container");
  const donBTn = $("#square-icon-container");
  const donBTn2 = $("#square-icon-container-mobile");
  if (
    !container.is(e.target) &&
    container.has(e.target).length === 0 &&
    !donBTn.is(e.target) &&
    donBTn.has(e.target).length === 0 &&
    !donBTn2.is(e.target) &&
    donBTn2.has(e.target).length === 0
  ) {
    $("#square-dropdown-container").removeClass(
      "square-dropdown-container-visible"
    );
    $("#square-icon-container").css({ background: "none" });
    $("#square-icon-container-mobile").css({ background: "none" });
  }

  const container1 = $("#rect-dropdown-container");
  const donBTn1 = $("#btn-question-header");
  if (
    !container1.is(e.target) &&
    container1.has(e.target).length === 0 &&
    !donBTn1.is(e.target) &&
    donBTn1.has(e.target).length === 0
  ) {
    $("#rect-dropdown-container").removeClass(
      "square-dropdown-container-visible"
    );
    // $('#square-icon-container').css({ background: 'none' });
  }

  const container2 = $(".notification-dropdown-container");
  // let btnn = $('#div-user-img-container');
  const userImg = $("#user-img");
  const instructorName = $("#div-instructor-name");
  const instructorDesignation = $("#div-instructor-designation");
  if (
    !container2.is(e.target) &&
    container2.has(e.target).length === 0 &&
    !userImg.is(e.target) &&
    userImg.has(e.target).length === 0 &&
    !instructorName.is(e.target) &&
    instructorName.has(e.target).length === 0 &&
    !instructorDesignation.is(e.target) &&
    instructorDesignation.has(e.target).length === 0
  ) {
    $(".notification-dropdown-container").removeClass(
      "notification-dropdown-container-visible"
    );
  }

  const containerShare = $("#div-share-link-main-container");
  const sharebtn = $(".new-link-container");
  if (
    !containerShare.is(e.target) &&
    containerShare.has(e.target).length === 0 &&
    !sharebtn.is(e.target) &&
    sharebtn.has(e.target).length === 0
  ) {
    $("#div-share-link-main-container").addClass("d-none");
  }
});

function closeProjectCreateNewDropdown() {
  $("#projectCreateNewDropdown").dropdown("dispose");
}

$(() => {
  $("#projectCreateNewDropdown form, #project-dropdown-header").click((e) => {
    e.stopPropagation();
  });
});



async function ConnectionStatusNotifier({
  connectedMsg = '<svg style="position: relative; top: -1px;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 25.93 25.93"><defs><style>.a{fill:#25a734;}</style></defs><path class="a" d="M12.965,0A12.965,12.965,0,1,0,25.93,12.965,12.965,12.965,0,0,0,12.965,0ZM20.1,8.989,10.841,18.25a.926.926,0,0,1-1.309,0l-3.7-3.7a.926.926,0,1,1,1.287-1.332l.023.023,3.05,3.05L18.793,7.68A.926.926,0,0,1,20.1,8.989Z"/></svg>&nbsp;&nbsp;Connected!',
  connectedMsgTimeout = 2000,
  disconnectedMsg = '<svg style="position: relative; top: 0px;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 57.611 54.289"><defs><style>.a{fill:#d61a1a;}</style></defs><g transform="translate(0 -14.759)"><g transform="translate(0 14.759)"><path class="a" d="M56.414,56.3,36.063,18.89a8.44,8.44,0,0,0-14.515,0L1.2,56.3A8.435,8.435,0,0,0,8.454,69.048h40.7A8.437,8.437,0,0,0,56.414,56.3Zm-27.608,6a3.376,3.376,0,1,1,3.376-3.376A3.38,3.38,0,0,1,28.805,62.3Zm3.376-13.5a3.376,3.376,0,0,1-6.751,0V31.916a3.376,3.376,0,1,1,6.751,0Z" transform="translate(0 -14.759)"/></g></g></svg>&nbsp;&nbsp;connection lost! retrying in 10 secs...',
  disconnectedVisibilityTimeout = 3000,
  reconnectingMsg = '<svg style="position: relative; top: 0px;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 57.611 54.289"><defs><style>.a{fill:#d61a1a;}</style></defs><g transform="translate(0 -14.759)"><g transform="translate(0 14.759)"><path class="a" d="M56.414,56.3,36.063,18.89a8.44,8.44,0,0,0-14.515,0L1.2,56.3A8.435,8.435,0,0,0,8.454,69.048h40.7A8.437,8.437,0,0,0,56.414,56.3Zm-27.608,6a3.376,3.376,0,1,1,3.376-3.376A3.38,3.38,0,0,1,28.805,62.3Zm3.376-13.5a3.376,3.376,0,0,1-6.751,0V31.916a3.376,3.376,0,1,1,6.751,0Z" transform="translate(0 -14.759)"/></g></g></svg>&nbsp;&nbsp;Trying to connect...',
  reconnectingVisibilityTimeout = 10000,
  htmlParentElement = "#connection-status-container",
} = {}) {
  let disconnectTimeout;
  let reconnectTimeout;

  $(window).on("online", () => {
    clearTimeout(disconnectTimeout);
    clearTimeout(reconnectTimeout);

    $(htmlParentElement).empty();
    $(htmlParentElement).append(connectedMsg);

    const timeout = setTimeout(() => {
      $(htmlParentElement).empty();

      clearTimeout(timeout);
    }, connectedMsgTimeout);
  });

  $(window).on("offline", () => {
    disconnectTimeout = setTimeout(() => {
      $(htmlParentElement).empty();
      $(htmlParentElement).append(disconnectedMsg);

      reconnectTimeout = setTimeout(() => {
        $(htmlParentElement).empty();
        $(htmlParentElement).append(reconnectingMsg);

        clearTimeout(reconnectTimeout);
      }, reconnectingVisibilityTimeout);

      clearTimeout(disconnectTimeout);
    }, disconnectedVisibilityTimeout);
  });
}
ConnectionStatusNotifier();

const logoutAllSessions = () => {
  const modal = document.getElementById("logout-all-session-modal");

  document
    .getElementById("close-logout-popup")
    .addEventListener("click", () => {
      modal.classList.remove("vissible-logout-session");
    });

  window.addEventListener("click", (event) => {
    if (event.target == modal) {
      modal.classList.remove("vissible-logout-session");
    }
  });

  modal.classList.add("vissible-logout-session");
};

// create project modal script
window.addEventListener(
  "DOMContentLoaded",
  () => {
    $("#createNewProjectModal").on("hidden.bs.modal", (e) => {
      $("#project-form-modal-projectTitle").val("");
      $("#project-form-modal-projectLanguage").val("");
      $("#project-form-modal-projectLanguage").removeAttr("disabled");
      $("#project-form-modal-remoteAccountType").val("0");
      $("#project-form-modal-remoteAccountType").removeAttr("disabled");
    });

    $("#project-form-modal-projectTitle").bind("input", function () {
      $(this).val((index, value) =>
        value.replace(/[^\w-]/gi, "").replace(/_/g, "")
      );
    });
  },
  false
);

function remoteAccountTypeChange(e) {
  const value = $(e.target).val();

  if (value !== "0") {
    // hide for no use of it
    $("#github-import-url-field").hide(300);
  } else {
    $("#github-import-url-field").hide(300);
  }
}

if (typeof lockForCreateProject === "undefined") {
  var lockForCreateProject = false;
}

function createProjectFromModal() {
  const projectName = $(
    "#project-create-new-form #project-form-modal-projectTitle"
  ).val();
  const language = $(
    "#project-create-new-form #project-form-modal-projectLanguage"
  ).val();
  const remoteAccountType = $(
    "#project-create-new-form #project-form-modal-remoteAccountType"
  ).val();
  const github_URL = $(
    "#project-create-new-form #project-form-modal-github-url"
  ).val();

  if (!projectName.trim().length) {
    toggleAlertMsgModal("add name of the project ",2);
    return;
  }

  if (/\s/g.test(projectName.trim())) {
    toggleAlertMsgModal("Spaces are not allowed in project title.",2);
    return false;
  }

  if (!language) {
    toggleAlertMsgModal("Select project language.",2);
    return false;
  }

  const url = "/project/createProject";
  const dataToSend = {
    projectName,
    language,
  };

  if (remoteAccountType != 0) {
    dataToSend.remoteAccountType = remoteAccountType;
    dataToSend.github_URL = github_URL;
  }

  if (lockForCreateProject) {
    return;
  }
  lockForCreateProject = true;

  toggleLoader(true);

  $.ajax({
    type: "POST",
    url,
    dataType: "json",
    contentType: "application/json",
    data: JSON.stringify(dataToSend),
    success(data) {
      if (data.error) {
        console.log(data.error);
        toggleLoader(false);
        toggleAlertMsgModal(data.error.error,2);
        lockForCreateProject = false;
      } else {
        toggleLoader(false);
        lockForCreateProject = false;

        window.location.href = `${PROJECTS_APP_HOST}/project/${data.name}-${data.uniqueId}`;
      }
    },
    error(jqXHRCode, textStatusCode, errCode) {
      toggleLoader(false);
      toggleAlertMsgModal(`Error in adding project, ${errCode}`,2);

      lockForCreateProject = false;
    },
  });
}

function handleSearch(e, _this) {
  let searchValue = $(_this).val();
  let keyCode = e.which || e.keyCode;

  if (keyCode === 13) {
    let uri = `/learning-modules?q=${searchValue}`;

    window.location.href = encodeURI(uri);
  }
}

$(() => {
  if (location.pathname == "/user-dashboard") {
    $("#homeIconMentor").addClass("active");
  } else if (location.pathname == "/acc") {
    $("#reportIconMentor").addClass("active");
  }
});


