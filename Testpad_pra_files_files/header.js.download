// for form notification
let socketForm = io();
socketForm.on('connect', function () {
  console.log("socket connected");
  socketForm.emit('getAssignedResponsesCount', {}, (data)=> {
    console.log('getAssignedResponsesCount', data);
    if(data && data.count) {
      $("#formNotificationCount").html(data.count).show();
    }else {
      $("#formNotificationCount").html('0').hide();
    }
  });
})

