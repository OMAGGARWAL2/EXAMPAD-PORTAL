$('.feedback-ballon-button').click(() => {
  if (!session.userId) {
    toggleLoginForm('/', `${window.location.href}?type=3`);
    return;
  }

  $('.feedback-ballon').toggleClass('feedback-ballon-visible');
});

function closeAllSelect(element) {
  let x = document.getElementsByClassName('select-items-2');
  let y = document.getElementsByClassName('select-selected-2');
  let arrNo = [];

  for (let i = 0; i < y.length; i++) {
    if (element == y[i]) {
      arrNo.push(i);
    } else {
      y[i].classList.remove('select-arrow-active');
    }
  }
  for (let i = 0; i < x.length; i++) {
    if (arrNo.indexOf(i)) {
      x[i].classList.add('select-hide-2');
    }
  }
}

// Report an Issue
function reportSend(event) {
  if (!$('#textAreaComment').val().trim().length) {
    toggleAlertMsgModal('Add some description', 2);
    return;
  }
  const dataToSend = { comment: $('#textAreaComment').val(),
    selectedOption: $("select[name='selectedOption']").val() };

  if (typeof tutorial !== 'undefined' && tutorial && tutorial._id) {
    dataToSend.contentType = 'tutorial';
    dataToSend.tutorialId = tutorial._id;
  } else if (typeof question !== 'undefined' && question && question._id) {
    dataToSend.contentType = 'question';
    dataToSend.questionId = question._id;
  }

  $.ajax({
    type: 'POST',
    url: '/submitFeedback',
    dataType: 'json',
    contentType: 'application/json',
    data: JSON.stringify(dataToSend),
    success(data) {
      if (data.error) {
        // notie.alert(3,data.error);
        toggleAlertMsgModal(data.error, 2);
      } else {
        $('#buttonSubmitReportProblem').blur();
        $('#textAreaComment').val('');
        $('.feedback-ballon').toggleClass('feedback-ballon-visible');
        // notie.alert(1,"Thanks for your feedback");
        toggleAlertMsgModal('Thanks for your feedback', 1);
      }
    },
    error(jqXHRCode, textStatusCode, errCode) {
      toggleAlertMsgModal(`Error in saving Feedabck${errCode}`,2);
    },
  });
};

// script for custom select box
$(document).ready(() => {
  let customSelect_2,
    selElmnt_2,
    tem_2p,
    temp2_2;
  customSelect_2 = document.getElementsByClassName('custom-select-2');
  for (let i = 0; i < customSelect_2.length; i++) {
    selElmnt_2 = customSelect_2[i].getElementsByClassName('selecttag1')[0];
    temp_2 = document.createElement('DIV');
    temp_2.setAttribute('class', 'select-selected-2');
    temp_2.innerHTML = selElmnt_2.options[selElmnt_2.selectedIndex].innerHTML;
    customSelect_2[i].appendChild(temp_2);
    temp2_2 = document.createElement('DIV');
    temp2_2.setAttribute('class', 'select-items-2 select-hide-2');
    for (let j = 0; j < selElmnt_2.length; j++) {
      let c;
      c = document.createElement('DIV');
      c.innerHTML = selElmnt_2.options[j].innerHTML;
      c.addEventListener('click', function (e) {
        let y;
        let k;
        let s = this.parentNode.parentNode.getElementsByTagName('select')[0];;
        let h = this.parentNode.previousSibling;

        for (let i = 0; i < s.length; i++) {
          if (s.options[i].innerHTML == this.innerHTML) {
            s.selectedIndex = i;
            h.innerHTML = this.innerHTML;
            y = this.parentNode.getElementsByClassName('same-as-selected');
            for (k = 0; k < y.length; k++) {
              y[k].removeAttribute('class');
            }
            this.setAttribute('class', 'same-as-selected');
            break;
          }
        }
        h.click();
      });
      temp2_2.appendChild(c);
    }
    customSelect_2[i].appendChild(temp2_2);
    temp_2.addEventListener('click', function (e) {
      e.stopPropagation();
      closeAllSelect(this);
      this.nextSibling.classList.toggle('select-hide-2');
      this.classList.toggle('select-arrow-active');
    });
  }

  $('#buttonSubmitReportProblem').click(reportSend);
});

// close feedback if click outside
$(document).mouseup((feedback) => {
  const feedbackContainer = $('#feedback_ballon_container');
  const feedbackBtn = $('#feedback_ballon_button');
  const feedBackNewBtn = $(".rprt-prblm-btn")
  if (
    !feedbackContainer.is(feedback.target)
    && feedbackContainer.has(feedback.target).length === 0
    && !feedbackBtn.is(feedback.target)
    && feedbackBtn.has(feedback.target).length === 0
    && !feedBackNewBtn.is(feedback.target)
    && feedBackNewBtn.has(feedback.target).length === 0
  ) {
    $('.feedback-ballon').removeClass('feedback-ballon-visible');
  }
});

document.addEventListener('click', closeAllSelect);