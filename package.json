{
    "name": "tespad",
    "productName": "TesPad",
    "version": "1.0.0",
    "description": "Custom ExamPad Environment",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "run": "electron .",
        "pack": "electron-builder build",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.custom.tespad",
        "win": {
            "target": "nsis",
            "icon": "icon.png"
        },
        "extraResources": [
            ".env"
        ]
    },
    "keywords": [
        "ERP",
        "Proctoring",
        "Secure"
    ],
    "author": "TESTPAD Engineering",
    "license": "ISC",
    "devDependencies": {
        "electron": "^28.3.3",
        "electron-builder": "^26.8.1"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "openai": "^6.25.0"
    },
    "type": "commonjs"
}
