function destroyCarousel() {
  $(".carousel3").waltzer("destroy");
}

function initCarousel() {
  $(".carousel3").waltzer({
    scroll: 1,
    circular: true
  });
}

const requestedSegmentArray = {};
const urlVals = window.location.pathname.split("/");
let isAdminView = false;
let currentStudentId = currentUserId;
if(urlVals[2] === "view") {
  isAdminView = true;
  currentStudentId = urlVals[3];
}

function openDiscussionUrl() {
  if ($('#discussion-url').css('display') == 'none') {
    toggleAlertMsgModal('discussion is disabled for this course.',2);
    if (!$('#course-content-container').children().hasClass('course-container')) {
      toggleAlertMsgModal('course is disabled.',2);
      $('#ok-btn-modal').click(() => {
        window.location.replace('/user-dashboard');
      });
      $('#close-btn-alert-msg').click(() => {
        window.location.replace('/user-dashboard');
      });
      window.addEventListener('click', (e) => {
        if (!document.getElementById('myModal-alert-only-2').contains(e.target)) {
          window.location.replace('/user-dashboard');
        }
      });
    }
    return;
  }
  $('#course-content-container').addClass('hide');
  $('#leaderBoadContainer').addClass('hide');
  $('#discussion-container').removeClass('hide');
  $('#discussion-url').addClass('active');
  $('#content-course').removeClass('active');
  $('#leaderBoard-btn').removeClass('active');
  // document.getElementById('page-desc-text').innerText = 'discussions';
  const dIframe = document.getElementById('discussion-iframe');
  // if (postId) {
  //   // dIframe.src = `${dIframe.src}?postId=${postId}`
  //   dIframe.src = `${discussionUrl}/discussion/embed-screen/${courseId}?postId=${postId}&timestamp=${Date.now()}`;
  // } else {
  //   // dIframe.src = dIframe.src;
  //   dIframe.src = `${discussionUrl}/discussion/embed-screen/${courseId}?timestamp=${Date.now()}`;
  // }

  dIframe.src = `${WORKSPACES_APP_HOST}/course/${courseId}?isEmbed`;
	// dIframe.src = `${WORKSPACES_APP_HOST}/course/${courseId}?isEmbed`;


  document.title = `Discussions - ${courseName} | CodeQuotient`;
  window.history.pushState( {} , null, `?discussion=true` );
}

/** @typedef {"section" | "assignment"} CarouselItemType */

const carouselItems = {
  /** @type {{ [K in CarouselItemType]: HTMLElement[] }} */
  elements: {
    section: [],
    assignment: []
  },
  /** @param {CarouselItemType} type */
  clear(type) {
    console.log("clear: ", type)
    const elements = this.elements[type];
    return elements.splice(0, elements.length);
  },
  /**
   * @param {CarouselItemType} type
   * @param {HTMLElement[]} items
   */
  add(type, items) {
    console.log("add: ", type)
    for(const item of items) {
      this.elements[type].push(item);
      item.remove();
    }
  }
};

const items = document.querySelectorAll(".item.segment-type-assignment");
carouselItems.add("assignment", items);

initCarousel();

function openContent(type = 0) {
  $('#course-content-container').removeClass('hide');
  $('#discussion-container').addClass('hide');
  $('#leaderBoadContainer').addClass('hide');
  $('#discussion-url').removeClass('active');
  $('#leaderBoard-btn').removeClass('active');
  $('#matrics-btn').removeClass('active');
  $("#metricsContainer").addClass('hide');

  if(type === 0) {
    if($("#content-course").hasClass("active")) {
      return;
    }
    $(".full-course-right-header").css("visibility", "visible");
    $(".course-topics.clicked").click();
    destroyCarousel();
    carouselItems.add("assignment", $(".segment-type-assignment"));
    $('#content-assignments').removeClass('active');
    $('#content-course').addClass('active');
  } else if(type === 1) {
    if($("#content-assignments").hasClass("active")) {
      return;
    }
    $(".full-course-right-header").css("visibility", "hidden");
    $(".course-topics.clicked").click();
    destroyCarousel();
    carouselItems.add("section", $(".segment-type-section"));
    $(".segment-type-section").addClass("hide");
    $('#content-course').removeClass('active');
    $('#content-assignments').addClass('active');
  }
  $(".carousel3").append(carouselItems.clear(type === 1 ? "assignment" : "section"));
  initCarousel();
  const segmentType = $(`.segment-type-${ type === 1 ? "assignment" : "section" }`);
  const noContentText = $(".no-content-text");
  const courseTopicsContainer = $(".course-topics-container");
  if (activeSegment) {
    return;
  }
  if(segmentType.length > 0) {
    noContentText.hide();
    courseTopicsContainer.show();
    segmentType[0].click();
  } else {
    courseTopicsContainer.hide();
    noContentText.text(`No ${ type === 1 ? "Assignment" : "Content" } Available`);
    noContentText.show();
  }
  // document.getElementById('page-desc-text').innerText = 'content';
  document.title = `${ type === 0 ? "Learning Content" : "Assignments" } - ${courseName} | CodeQuotient`;
  window.history.pushState( {} , null, `?${ type === 0 ? "" : "type=assignment&" }discussion=false` );
}

let leaderboardDataTable = null;

function openLeaderboard() {
  $(".full-course-right-header").css("visibility", "hidden");
  $('#content-course').removeClass('active');
  $('#content-assignments').removeClass('active');
  $('#discussion-container').addClass('hide');
  $('#matrics-btn').removeClass('active');
  $('#course-content-container').addClass('hide');
  $('#metricsContainer').addClass('hide');
  $('#leaderBoadContainer').removeClass('hide');
  $('#discussion-url').removeClass('active');
  $('#content-course').removeClass('active');
  $('#matrics-btn').removeClass('active');
  $('#leaderBoard-btn').addClass('active');
  $("#leaderboardTabTop").prepend($("#leaderboardTabSelectHolder"));

  // document.getElementById('page-desc-text').innerText = 'leaderboard';
  document.title = `Leaderboard - ${courseName} | CodeQuotient`;
  window.history.pushState({} , null, `?type=leaderboard&discussion=false`);
  if(document.readyState === "complete") {
    loadLeaderboardData(courseId, currentStudentId);
    return;
  }
  window.addEventListener("load", () => loadLeaderboardData(courseId, currentStudentId), { once: true });
}

async function openMatrics() {
  const matricsButton = document.getElementById('matrics-btn');
  if(matricsButton) {
    matricsButton.style.display = "inline-block";
  }
  $(".full-course-right-header").css("visibility", "hidden");
  $('#content-course').removeClass('active');
  $('#content-assignments').removeClass('active');
  $('#discussion-container').addClass('hide');
  $('#course-content-container').addClass('hide');
  $('#leaderBoadContainer').addClass('hide');
  $('#metricsContainer').removeClass('hide');
  $('#discussion-url').removeClass('active');
  $('#content-course').removeClass('active');
  $('#leaderBoard-btn').removeClass('active');
  $('#matrics-btn').addClass('active');
  // document.getElementById('page-desc-text').innerText = 'leaderboard';
  if(courseName) {
    document.title = `Matrics - ${courseName} | CodeQuotient`;
    window.history.pushState({} , null, `?type=matrics&discussion=false`);
  }
  $("#metricsTabTop").prepend($("#leaderboardTabSelectHolder"));

  if(document.readyState === "complete") {
    loadMetricsData(courseId, currentStudentId);
    return;
  }
  window.addEventListener("load", () => {
    loadMetricsData(courseId, currentStudentId);
  }, { once: true });
}

initLeaderboard(courseId, currentStudentId);
initMetrics(courseId, currentStudentId);

let currentSortScore = 'asc';
let currentSortName = 'asc';
let currentUserDetail = {};

function sortScore() {
  if (currentSortScore == 'asc') {
    leaderBoardData.data.sort((a, b) => a.completed - b.completed);
    currentSortScore = 'desc';
  } else {
    leaderBoardData.data.sort((a, b) => b.completed - a.completed);
    currentSortScore = 'asc';
  }
  $('#leaderBoard-list').empty();
  let count = 1;
  leaderBoardData.data.map((val, ind) => {
    const score = val.completed == null ? '0' : val.completed;
    if (currentUserDetail.id != val.user_id) {
      $('#leaderBoard-list').append(`
        <div class="leaderboard-list">
            <p class="user-name">${count}. ${val.displayname}</p>
            <p class="user-score">${score}</p>
          </div>
      `);
    }
    count++;
    if (leaderBoardData.data[ind + 1] && ((val.completed == null ? '0' : val.completed) == (leaderBoardData.data[ind + 1].completed == null ? '0' : leaderBoardData.data[ind + 1].completed))) {
      count--;
    }
  });
  $('#leaderBoard-list').prepend(`
    <div class="leaderboard-list selected">
      <p class="user-name">${currentUserDetail.rank}. ${currentUserDetail.name}</p>
      <p class="user-score">${currentUserDetail.score}</p>
    </div>
  `);
}

function sortName() {
  if (currentSortName == 'asc') {
    leaderBoardData.data.sort((a, b) => {
      if (a.displayname < b.displayname) {
        return -1;
      }
      if (a.displayname > b.displayname) {
        return 1;
      }
      return 0;
    });
    currentSortName = 'desc';
  } else {
    leaderBoardData.data.sort((a, b) => {
      if (a.displayname < b.displayname) {
        return 1;
      }
      if (a.displayname > b.displayname) {
        return -1;
      }
      return 0;
    });
    currentSortName = 'asc';
  }
  $('#leaderBoard-list').empty();
  let count = 1;
  leaderBoardData.data.map((val, ind) => {
    const score = val.completed == null ? '0' : val.completed;
    if (currentUserDetail.id != val.user_id) {
      $('#leaderBoard-list').append(`
        <div class="leaderboard-list">
            <p class="user-name">${count}. ${val.displayname}</p>
            <p class="user-score">${score}</p>
          </div>
      `);
    }
    count++;
    if (leaderBoardData.data[ind + 1] && ((val.completed == null ? '0' : val.completed) == (leaderBoardData.data[ind + 1].completed == null ? '0' : leaderBoardData.data[ind + 1].completed))) {
      count--;
    }
  });
  $('#leaderBoard-list').prepend(`
    <div class="leaderboard-list selected">
      <p class="user-name">${currentUserDetail.rank}. ${currentUserDetail.name}</p>
      <p class="user-score">${currentUserDetail.score}</p>
    </div>
  `);
}

const urlParams = new URLSearchParams(window.location.search);
const myParam = urlParams.get('discussion');
const postId = urlParams.get('postId');
const leaderBoardParam = urlParams.get('leaderboard');
const type_param = urlParams.get("type");

if(type_param) {
  if(type_param === "leaderboard") {
    openLeaderboard();
  } else if (type_param === "matrics") {
    openMatrics();
  } else {
    openContent(type_param === "assignment" ? 1 : 0);
  }
} else if (myParam == 'true') {
  openDiscussionUrl();
} else if (leaderBoardParam == 'true') {
  openLeaderboard();
}

async function getCourseDiscussionCount() {
  toggleLoader(true);
  try {
    const courseMsgCount = await fetch(`${discussionUrl}/api/discussion/user-count?discussions=${courseId}`, {
      credentials: 'include',
      method: 'GET',
      headers: {
        'Content-Type': 'application/json',
      },
    });
    if(courseMsgCount.redirected) {
      if(courseMsgCount.url && courseMsgCount.url.indexOf('login') > -1) location.reload();
      else window.location = `${courseMsgCount.url}`;
    }
    const finalCourseMsgCount = await courseMsgCount.json();
    if (finalCourseMsgCount.counts[0].count > 0) {
      document.getElementById('course-discussion-count').innerText = finalCourseMsgCount.counts[0].count;
    }
  } catch (err) {
    console.error(err);
  } finally {
    toggleLoader(false);
  }
}

