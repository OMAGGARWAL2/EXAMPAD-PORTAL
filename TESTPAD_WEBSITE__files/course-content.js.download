$(document).ready(() => {
  $('.mask .innerWrapper').each(function (val, ind) {
    const totalSegments = $(ind).children().length;
    if (totalSegments <= 4 && window.innerWidth >= 1070) {
      $(this).parent().parent().find('.left-nav-btn')
        .attr('disabled', 'disabled')
        .off('click')
        .css({ cursor: 'not-allowed' });
      $(this).parent().parent().find('.right-nav-btn')
        .attr('disabled', 'disabled')
        .off('click')
        .css({ cursor: 'not-allowed' });
    }

      const downloadCourseReportButton = document.getElementById("downloadCourseReportButton");
      downloadCourseReportButton.addEventListener("click", async function() {
        const courseUserReport = new CourseUserReport(courseId, currentStudentId);
	      await courseUserReport.download({ isChitkara });
      });
  });
  // getCourseMsgCount();

  // open last segment
  try {
    if (activeSegment == undefined && resumeSId != undefined && type_param !== "assignment") {
      $(`.segment-type-section.deaultOpen_${resumeSId}`).trigger('click');
    }
    if (activeSegment != undefined) {
      $(`#segment_${courseId}_${activeSegment}`).click();
    } else if(resumeSId !== undefined) {
      $(".segment-type-section")[0].trigger?.('click');
    }
  } catch (err) {
    console.log(err);
  }

  let urlVals = window.location.pathname.split('/');
  let currentStudentId = currentUserId;
  if(urlVals[2] == 'view'){
    currentStudentId = urlVals[3];
    $("#discussion-url").hide()
    $(".attempts-tab").hide()
    $(".resume-btn").hide()
    $('.progress-bar-container-mobile-view').css('margin-top','22px');
    $('.isQuestionModal').removeAttr('href');

    $(document).on("click", ".isQuestionModal", function (e) {
      // return;
      e.preventDefault();
      var id = $(this).attr("quesid").trim();
      var href = "/quest/viewques/id:"+id;
      var typeOfQuestion = $(this).closest('td').next('td').text();
      //-- Ajax call
      $.ajax({
          url: href,
          dataType: 'json',
          success: function (html) {
              var updatedon = new Date(html.questiondata.updatedAt);
              updatedon = updatedon.getFullYear()+'/'+(updatedon.getMonth()+1)+'/'+updatedon.getDate();
              var headerofmpdalbox = html.questiondata.title+'<div style="font-size:10pt">';
              if(!(html.questiondata.type === '1' ||  html.questiondata.type === '2' ||  html.questiondata.type === '9')) {
                  headerofmpdalbox += '<span>Test Cases : '+html.questiondata.questionTypeCoding.testCase.length+'</span>&nbsp&nbsp&nbsp';
              }
 
              headerofmpdalbox += '<span>Updated On : '+updatedon+'</span></div>';
              var testCases="" ;
              if(html.questiondata.type === '5'){
 
                  html.questiondata.questionTypeCoding.testCase.forEach((tc,index)=>{
                      testCases += (index + 1) + ".) " + tc.codeproginputparams+" = &nbsp;<input style='height:20px ;resize:none' readonly></input><br/></br>" ;
                  })
              }
              $('.modal-body').html(html.html + testCases);
              $('.modal-title').html(headerofmpdalbox);
              //--
              $('#divDetailsModal').modal("show");
          },
          error: function (jqXHR, textStatus, err) {
              //-- show error message
              //alert('text status ' + textStatus + ', err ' + err);
              // toggleAlertMsgModal("Error fetching the question details.", 2);
          }
      });
  });
  }
});

async function getCourseTestsCount(courseId) {
  try {
    const url = new URL(`/api/user-dashboard/tests/${ courseId }`, location.origin);
    url.searchParams.append("activeTestOnly", 1);
    const rowResponse = await fetch(url);
    const response = await rowResponse.json();
    return response.quiz.reduce((previousValue, currentValue) => {
      return previousValue + Number("userAttempt" in currentValue === false || currentValue.userAttempt.attempted === false )
    }, 0);
  } catch(ex) {
    console.log(ex);
    return 0;
  }
}

async function getCourseTests(courseId) {
  try {
    const rowResponse = await fetch(`/api/user-dashboard/tests/${courseId}`);
    const response = await rowResponse.json();
    return response.quiz;
  } catch(ex) {
    console.log(ex);
    return [];
  }
}

/**
 * @param {MouseEvent} event
 * @param {boolean} isAssignment
 * @param {number} sectionIndex
 */
async function downloadCourseSectionPDF(event, isAssignment, sectionIndex) {
  event.stopPropagation();
  const urlVals = window.location.pathname.split("/");
  const currentStudentId = urlVals[2] === "view" ? urlVals[3] : currentUserId;
  const courseUserReport = new CourseUserReport(courseId, currentStudentId, { sectionIndex });
  await courseUserReport.download({ isChitkara });
}

async function handleOpenFile(courseId, questionId, fileName, downloadURL) {
  const url = `/attempt/attemptFileQuestion/${courseId}/${questionId}`;
  openFilePreviewDialog(url, fileName, downloadURL);
}
